{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Piyo",
    "version": "0.1.0",
    "identifier": "sh.piyo",
    "build": {
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "piyo",
                "width": 1000,
                "height": 600,
                "transparent": true,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "trafficLightPosition": { "x": 16, "y": 24 }
            }
        ],
        "macOSPrivateApi": true,
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": ["shell/**/*"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
