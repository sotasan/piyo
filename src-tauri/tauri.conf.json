{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Piyo",
    "identifier": "sh.piyo",
    "build": {
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "piyo",
                "width": 1000,
                "height": 600,
                "transparent": true,
                "visible": false,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "trafficLightPosition": { "x": 16, "y": 24 }
            }
        ],
        "macOSPrivateApi": true,
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "resources": ["bin/**/*", "shell/**/*"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMwRTYzMjRBN0ZGOUFCMUQKUldRZHEvbC9Takxtd0hvaVNBYjk2RnVCSTVxS1Y4aTNMNWdzQ2RKQ3NMNUkxZGdSRjJqY0JVaGoK",
            "endpoints": ["https://github.com/sotasan/piyo/releases/latest/download/latest.json"]
        }
    }
}
