#!/bin/sh
# Shim that wraps the real `claude` binary so piyo can:
#   1. Drop the shim's own directory from PATH (otherwise the exec below
#      would recurse into this script forever).
#   2. Capture the controlling tty so claude's Stop hook can write its
#      OSC 7496 notification straight to the terminal — the hook runs as
#      a child of claude with no controlling tty, so /dev/tty fails for
#      it (the parent shim still uses /dev/tty fine for its own writes).
#   3. Masquerade as Ghostty (TERM_PROGRAM) so claude enables three
#      ghostty-gated features that piyo actually supports: OSC 9;4
#      progress reports (drive the tab loading spinner), the OSC 777
#      notification channel (permission prompts etc. -> native OS
#      notifications), and pushing kitty keyboard mode 1 itself so
#      Shift+Enter reads as a distinct key. All three are gated on
#      TERM_PROGRAM==="ghostty" plus a version floor (see ykH/qM3 in
#      claude's bundle), so the version is faked high enough to clear the
#      >=1.2.0 check. Scoped to this shim so the rest of the session
#      still reports TERM_PROGRAM=piyo. With the spoof, claude's "auto"
#      notif channel resolves to ghostty on its own (no
#      preferredNotifChannel needed) and claude pushes/pops the kitty
#      protocol itself (verified — under TERM_PROGRAM=piyo it does not,
#      so the shim used to push it manually; now it doesn't need to,
#      which means Shift+Enter rides on this spoof too). The Stop event
#      is covered by none of this, hence the hook below.
#   4. Wire a Stop hook that forwards Claude's turn-end JSON inside an
#      OSC 7496 sequence — piyo's OSC parser extracts the last assistant
#      message and fires a native OS notification. Newlines are stripped
#      from the payload so xterm.js doesn't treat them as a sequence
#      terminator and leak the trailing BEL onto the screen.
#   5. exec into claude rather than running it as a child, so claude
#      inherits the shim's pid and is the tty's foreground pgrp leader —
#      otherwise piyo's close-confirmation dialog reports the foreground
#      process as "sh"/"bash" instead of "claude". The codex shim hands
#      off the same way. The TERM_PROGRAM spoof is exported just above
#      the exec — only claude and its children inherit it, never the
#      parent shell (an inline `VAR=val exec` prefix is unreliable per
#      POSIX, hence export rather than a prefix).
self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd) || exit 1
PATH=$(printf %s "$PATH" | tr : '\n' | grep -vxF "$self_dir" | paste -sd: -)

PIYO_TTY=$(tty 2>/dev/null) || PIYO_TTY=/dev/tty
export PIYO_TTY

export TERM_PROGRAM=ghostty
export TERM_PROGRAM_VERSION=1.2.0

exec claude --settings '{
    "hooks": {
        "Stop": [{
            "hooks": [{
                "type": "command",
                "command": "{ printf \"\\033]7496;claude;stop;\"; tr -d \"\\012\"; printf \"\\007\"; } > \"$PIYO_TTY\" 2>/dev/null"
            }]
        }]
    }
}' "$@"
