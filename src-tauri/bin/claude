#!/bin/sh
self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd) || exit 1
PATH=$(printf %s "$PATH" | tr : '\n' | grep -vxF "$self_dir" | paste -sd: -)
exec claude --settings '{
    "hooks": {
        "Stop": [{
            "hooks": [{
                "type": "command",
                "command": "if [ -w /dev/tty ]; then OUT=/dev/tty; else OUT=/dev/stderr; fi; { printf \"\\033]7496;claude;stop;\"; cat; printf \"\\007\"; } > \"$OUT\" 2>/dev/null"
            }]
        }]
    }
}' "$@"
