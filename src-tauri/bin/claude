#!/bin/sh
# Shim that wraps the real `claude` binary so piyo can:
#   1. Drop the shim's own directory from PATH (otherwise the exec below
#      would recurse into this script forever).
#   2. Capture the controlling tty so claude's Stop hook can write its
#      OSC 7496 notification straight to the terminal — the hook runs as
#      a child of claude with no controlling tty, so /dev/tty fails for
#      it (the parent shim still uses /dev/tty fine for its own writes).
#   3. Enable Claude Code's built-in Ghostty-style notification channel
#      so *Notification* events (permission prompts etc.) arrive as
#      OSC sequences that piyo's host turns into native OS notifications.
#      preferredNotifChannel doesn't cover Stop, hence the hook below.
#   4. Wire a Stop hook that forwards Claude's turn-end JSON inside an
#      OSC 7496 sequence — piyo's OSC parser extracts the last assistant
#      message and fires a native OS notification. Newlines are stripped
#      from the payload so xterm.js doesn't treat them as a sequence
#      terminator and leak the trailing BEL onto the screen.
#   5. Push kitty keyboard mode 1 for the duration of claude — claude
#      relies on the disambiguated encoding to see Shift+Enter as a
#      distinct key. The shell init doesn't push it (would rewrite
#      Ctrl+C as CSI-u and break SIGINT for cooked-mode commands like
#      `tree`), so the shim does it itself and pops on every exit path.
#   6. Enable monitor mode so claude becomes its own pgrp leader and the
#      tty's foreground pgrp. Without it the shim's sh stays as the pgrp
#      leader and piyo's close-confirmation dialog reports the foreground
#      process as "sh"/"bash" instead of "claude". `exec` would solve it
#      too but kills the trap below.
self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd) || exit 1
PATH=$(printf %s "$PATH" | tr : '\n' | grep -vxF "$self_dir" | paste -sd: -)
PIYO_TTY=$(tty 2>/dev/null) || PIYO_TTY=/dev/tty
export PIYO_TTY

set -m
trap 'printf "\033[<u" > /dev/tty 2>/dev/null' EXIT TERM HUP
printf '\033[>1u' > /dev/tty 2>/dev/null

claude --settings '{
    "preferredNotifChannel": "ghostty",
    "hooks": {
        "Stop": [{
            "hooks": [{
                "type": "command",
                "command": "{ printf \"\\033]7496;claude;stop;\"; tr -d \"\\012\"; printf \"\\007\"; } > \"$PIYO_TTY\" 2>/dev/null"
            }]
        }]
    }
}' "$@"
