#!/bin/sh
# Shim that wraps the real `codex` binary so piyo can:
#   1. Drop the shim's own directory from PATH (otherwise the exec below
#      would recurse into this script forever).
#   2. Inject the bundled `codex-notify` helper as codex's `notify`
#      handler so codex's "agent paused / done" events surface to the
#      terminal as OSC 7496 sequences that piyo's host picks up.
# If `codex-notify` isn't installed alongside (e.g. resources weren't
# resolved, or someone is running the binary outside piyo), fall through
# to a plain codex exec so the user still gets a working CLI.
self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd) || exit 1
PATH=$(printf %s "$PATH" | tr : '\n' | grep -vxF "$self_dir" | paste -sd: -)

if [ -x "${PIYO_SCRIPTS-}/codex-notify" ]; then
    exec codex -c "notify=['$PIYO_SCRIPTS/codex-notify']" "$@"
fi
exec codex "$@"
