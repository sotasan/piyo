.DS_Store

# dependencies (bun installs at the workspace root)
node_modules/

# Swift Package Manager
.build/
.swiftpm/

# zmx multiplexer (built from vendored zmx source)
/Resources/bin/

# Vendored deps — populated by `vendir sync` (pinned in vendir.lock.yml)
/vendor/

# Generated Xcode project + build output (xcodegen / xcodebuild)
/Piyo.xcodeproj/
/.build-xcode/
DerivedData/
xcuserdata/
*.xcuserstate

.env

# SourceKit-LSP build server config (machine-local, absolute DerivedData path)
buildServer.json

# cargo workspace build output
/target

# release build output (dmg + appcast)
/dist/
